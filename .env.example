# Clé API Resend — https://resend.com/api-keys
# Créer un compte Resend, générer une clé dans Settings > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email destinataire des demandes de devis
# C'est l'adresse qui recevra chaque formulaire soumis
QUOTE_RECIPIENT_EMAIL=a.k.silva9@gmail.com

# Adresse expéditrice des emails de devis
# Par défaut : onboarding@resend.dev (adresse de test Resend — fonctionne sans domaine vérifié)
# En production : remplacer par une adresse sur un domaine vérifié dans Resend
#   ex : "DPM Marigot <devis@dpm-marigot.fr>"
# Voir : https://resend.com/domains
EMAIL_FROM=DPM Marigot <onboarding@resend.dev>
